<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Medicare" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/colorBackground</item>
        <!-- Base Font -->
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>
    
    <!-- Rounded Button Style -->
    <style name="Widget.Medicare.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans_bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingVertical">12dp</item>
    </style>

    <!-- Card Style (Tonal Architecture) -->
    <style name="Widget.Medicare.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">0dp</item>
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Medicare.TimePicker" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <item name="android:timePickerMode">spinner</item>
        <!-- Force Button Text Colors -->
        <item name="colorAccent">@color/colorPrimary</item>
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
    </style>
</resources>
